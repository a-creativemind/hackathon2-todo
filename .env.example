# ===========================================
# Docker Compose Environment Variables
# Copy to .env and fill in your values
# ===========================================

# Database (PostgreSQL container for local dev)
POSTGRES_USER=todouser
POSTGRES_PASSWORD=todopass
POSTGRES_DB=tododb
DATABASE_URL=postgresql://todouser:todopass@db:5432/tododb

# OpenAI (required for AI agent)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Clerk Authentication
# Get these from https://dashboard.clerk.com -> API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-key-here
CLERK_SECRET_KEY=sk_test_your-key-here

# Backend
BACKEND_PORT=8000

# Todo Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
TODO_FRONTEND_PORT=3000

# Chatbot Frontend
FRONTEND_PORT=3001

# ── Grafana (OKE monitoring) ──────────────────────────────────────────────────
# Password for the Grafana admin user. Choose any strong password.
# Used to log in at: kubectl port-forward svc/kube-prometheus-stack-grafana 3000:80 -n monitoring
# then open http://localhost:3000  (username: admin)
GRAFANA_ADMIN_PASSWORD=your-grafana-admin-password

# ── Kafka / Redpanda Cloud ────────────────────────────────────────────────────
# Get these from: https://cloud.redpanda.com → your cluster → Overview + Security
#
# KAFKA_BROKERS  → cluster Overview page → "Bootstrap server URL"
#                  Format: seed-xxxxxxxx.<region>.redpanda.cloud:9092
#
# KAFKA_API_KEY  → Security → Users → your SASL/SCRAM user → username
#
# KAFKA_API_SECRET → Security → Users → your SASL/SCRAM user → password
#                    (only shown once at creation — save it securely)
KAFKA_BROKERS=seed-xxxxxxxx.xxxxxxxxx.redpanda.cloud:9092
KAFKA_API_KEY=your-redpanda-sasl-username
KAFKA_API_SECRET=your-redpanda-sasl-password

# ── OKE / Production ──────────────────────────────────────────────────────────

# CORS: comma-separated browser origins allowed to call the backend.
# Dev defaults are set automatically in backend/main.py.
# For OKE: add the Load Balancer IP after first deploy, e.g.:
#   http://150.xxx.xxx.xxx,https://todo.example.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://just-crayfish-7.clerk.accounts.dev

# External backend URL used for smoke tests and CI/CD health checks.
# Set to the OKE nginx-ingress LoadBalancer external IP after first deploy.
# /health and /ready are routed through the ingress to the backend directly.
# Example: http://150.xxx.xxx.xxx
BACKEND_URL=http://localhost:8000
